# ============================================================
# DFIR-IRIS + Cortex — Universal Stack v2
# cp .env.example .env  →  edit all CHANGE_ME values
#
# VERSION PINS — edit these to upgrade any component:
#   bash scripts/update.sh   (pulls new images + restarts)
# ============================================================

# ── Component Versions ───────────────────────────────────────
# IRIS:    https://github.com/dfir-iris/iris-web/releases
# Cortex:  https://github.com/TheHive-Project/Cortex/releases
# ES:      https://www.elastic.co/downloads/elasticsearch
#          !! ES must be 8.x for Cortex 4.x  (7.x = NOT supported) !!
IRIS_VERSION=v2.4.27
CORTEX_VERSION=latest
ES_VERSION=8.13.0

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=iris
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_ADMIN_USER=iris_admin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_admin_password
# !! Must equal POSTGRES_USER !!
POSTGRES_DB=iris

# ── IRIS App Secrets ─────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# !! Must be SECRET_KEY / SECURITY_PASSWORD_SALT (no IRIS_ prefix) !!
SECRET_KEY=CHANGE_ME_secret_key_min_32_chars
SECURITY_PASSWORD_SALT=CHANGE_ME_password_salt

# ── IRIS DB connection ───────────────────────────────────────
DB_PASS=CHANGE_ME_db_password
DB_USER=iris
DB_NAME=iris
DB_HOST=db
DB_PORT=5432

# ── Nginx / TLS ──────────────────────────────────────────────
INTERFACE_HTTPS_PORT=443
CERT_FILENAME=iris.crt
KEY_FILENAME=iris.key
IRIS_AUTHENTICATION_TYPE=local

# ── Cortex Secret Key ────────────────────────────────────────
# Play framework secret key for Cortex
# Auto-generated by setup.sh via: openssl rand -base64 48
# Referenced in cortex/config/application.conf as ${?CORTEX_SECRET_KEY}
CORTEX_SECRET_KEY=CHANGE_ME_cortex_secret_key

# ── Cortex Integration ───────────────────────────────────────
# Set AFTER running Cortex first-time setup:
#   Cortex UI → Organisation → API Keys → Create
CORTEX_API_KEY=CHANGE_ME_cortex_api_key
